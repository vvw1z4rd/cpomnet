config network simulations.ned.CampusNetwork
config sim-time-limit 40s
config repeat 5
config seed-set 0
config **.crcMode "\"declared\""
config **.fcsMode "\"declared\""
config **.ipv4.checksum.typename InternetChecksum
config *.configurator.typename inet.networklayer.configurator.ipv4.Ipv4NetworkConfigurator
config *.configurator.addStaticRoutes true
config *.configurator.assignDisjunctSubnetAddresses true
config *.configurator.addDefaultRoutes true
config *.server1.numApps 1
config *.server1.app[*].typename UdpSink
config *.server1.app[*].localPort 5000
config *.server2.numApps 1
config *.server2.app[*].typename UdpSink
config *.server2.app[*].localPort 5001
config *.numBranch1Hosts 20
config *.numBranch2Hosts 20
config *.branch1Host[*].numApps 1
config *.branch1Host[*].app[*].typename UdpBasicApp
config *.branch1Host[*].app[*].destAddresses "\"server1\""
config *.branch1Host[*].app[*].destPort 5000
config *.branch1Host[*].app[*].startTime 0s
config *.branch1Host[*].app[*].stopTime 39s
config *.branch1Host[*].app[*].messageLength 1200B
config *.branch1Host[*].app[*].sendInterval exponential(0.07s)
config *.branch2Host[*].numApps 1
config *.branch2Host[*].app[*].typename UdpBasicApp
config *.branch2Host[*].app[*].destAddresses "\"server2\""
config *.branch2Host[*].app[*].destPort 5001
config *.branch2Host[*].app[*].startTime 0s
config *.branch2Host[*].app[*].stopTime 39s
config *.branch2Host[*].app[*].messageLength 1200B
config *.branch2Host[*].app[*].sendInterval exponential(0.07s)
config **.vector-recording true
config **.scalar-recording true
config **.endToEndDelay.vector-recording true
config *.scenarioManager.script "xml(\"<scenario><at t='10.0s'><shutdown module='mainRouter'/></at></scenario>\")"

